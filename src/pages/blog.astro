---
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = [
  {
    title: 'building this website',
    description: 'the journey of designing my personal site',
    date: '2026-03-09',
    slug: 'building-this-website',
  },
  {
    title: 'learning looks like recursion',
    description: 'mindset',
    date: '2025-05-12',
    slug: 'learning-looks-like-recursion',
  },
];
---

<BaseLayout title="nitesh — blog" description="thoughts">
  
  <!-- CENTER PANE: Blog Posts -->
  <Fragment>
    <div class="flex flex-col text-[0.85rem]">
      <div class="mb-6 pb-2 text-cyan-400 border-b border-dusty-800">
        [ posts ]
      </div>

      <ul>
        {posts.map(post => (
          <li class="blog-entry group border-b border-dusty-800/50 hover:bg-white/5 transition px-2 -mx-2 rounded">
            <div class="flex flex-col">
              <a href={`/blog/${post.slug}`} class="text-[#eeeeee] group-hover:text-cyan-400 font-medium">
                {post.title}
              </a>
              <span class="muted text-[0.8rem] mt-0.5">{post.description}</span>
            </div>
            <span class="blog-entry-date shrink-0 ml-4 font-mono">{post.date}</span>
          </li>
        ))}
      </ul>
    </div>
  </Fragment>

</BaseLayout>
