---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="nitesh — whoami" description="nitesh's background and skills">
  
  <!-- CENTER PAN: Text Content -->
  <Fragment>
    <div class="flex flex-col gap-6 text-[0.85rem] leading-relaxed text-dusty-500">
      <p>
        hey! my name is <strong class="font-bold text-cyan-400">nitesh</strong>
      </p>

      <p>
        i am a <strong class="font-bold text-[#eeeeee]">AI/ML oriented engineer</strong> I work across the whole stack — backend systems, APIs, agent workflows, RAG pipelines — and when something interests me enough I go deeper, like actually looking at how models represent information internally rather than just using them as a black box.
      </p>

      <p>
        i thrive best in environments that value <strong class="font-bold text-[#eeeeee]">high velocity</strong> and <strong class="font-bold text-[#eeeeee]">strong ownership</strong>
      </p>

      <p class="text-dusty-500">
        I'm learning how to act as an <strong class="font-bold text-[#eeeeee]">Agent Orchestrator</strong> and Linux ricing and customizing workflows In my spare time :D
      </p>

      <!-- Skills Section -->
      <div class="mt-4 border-t border-dusty-800 pt-6">
        <div class="mb-4 text-cyan-400 text-base font-bold">skills</div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-y-6 gap-x-8">
          <!-- languages -->
          <div class="flex flex-col gap-2">
            <span class="text-[#eeeeee] font-bold">languages</span>
            <span class="muted text-[0.8rem]">Python (primary), C, JavaScript, bash/zsh</span>
          </div>
          
          <!-- backend -->
          <div class="flex flex-col gap-2">
            <span class="text-[#eeeeee] font-bold">backend</span>
            <span class="muted text-[0.8rem]">FastAPI, Django, Pydantic</span>
          </div>

          <!-- infrastructure & tools -->
          <div class="flex flex-col gap-2">
            <span class="text-[#eeeeee] font-bold">infrastructure & tools</span>
            <span class="muted text-[0.8rem]">Docker, Git, GitHub Actions, Linux, kubernetes, PostgreSQL (pgvector), ChromaDB, MongoDB</span>
          </div>

          <!-- AI & ML -->
          <div class="flex flex-col gap-2">
            <span class="text-[#eeeeee] font-bold">AI & ML</span>
            <span class="muted text-[0.8rem]">LLMs, Agents, Diffusion, MCP (Model Context Protocol), RAG Pipelines, LangChain, HuggingFace</span>
          </div>
        </div>
      </div>
    </div>
  </Fragment>

  <!-- RIGHT PAN: ASCII Art -->
  <Fragment slot="right-pane">
    <div class="font-mono text-[0.6rem] text-dusty-700 leading-none whitespace-pre select-none mt-2">
{`   ┌───────────────┐
   │ >_ TERMINAL  -│
   ├───────────────┤
   │               │
   │  SYSTEM LOAD  │
   │  ||||||       │
   │               │
   │  MEM  64%     │
   │  CPU  12%     │
   │               │
   └───────────────┘`}
    </div>
  </Fragment>

</BaseLayout>
