---
import '../styles/global.css';

interface Props {
  frontmatter: {
    title: string;
    description?: string;
    date: string;
  };
}

const { frontmatter } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/', label: 'home' },
  { href: '/whoami', label: 'whoami' },
  { href: '/work', label: 'work' },
  { href: '/blog', label: 'blog' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={frontmatter.description || ''} />
    <title>nitesh — {frontmatter.title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="flex min-h-screen items-start justify-center p-4 sm:p-6 pt-16 md:pt-24 lg:pt-32 bg-dusty-900 text-dusty-500">
    
    <div class="flex w-full max-w-[720px] flex-col md:flex-row md:items-start mx-auto gap-0">
      
      <!-- LEFT: Navigation -->
      <aside class="flex w-full shrink-0 flex-col md:w-[100px] md:items-end md:pr-3 mb-4 md:mb-0 md:border-r border-dusty-700">
        <nav class="nav-list text-left md:text-right flex flex-col gap-0.5 text-[0.8rem] font-mono">
          {navItems.map(link => {
            const isActive = link.href === '/blog';
            return (
              <a
                href={link.href}
                class:list={[
                  'hover:text-[#eeeeee] transition-colors',
                  isActive ? 'text-[#eeeeee] font-bold' : 'text-dusty-500'
                ]}
              >
                {isActive ? `[ ${link.label} ]` : `  ${link.label}  `}
              </a>
            );
          })}
        </nav>
      </aside>

      <!-- CENTER: Blog Post Content -->
      <div class="flex flex-1 flex-col md:flex-row">
        <main class="w-full md:w-[600px] shrink-0 md:pl-3">
          
          <!-- Back link -->
          <a href="/blog" class="text-dusty-500 hover:text-cyan-400 text-[0.8rem] mb-6 inline-block transition-colors">
            ← back to posts
          </a>

          <!-- Post Header -->
          <header class="mb-8 border-b border-dusty-800 pb-6">
            <h1 class="text-xl font-bold text-[#eeeeee] mb-2">{frontmatter.title}</h1>
            {frontmatter.description && (
              <p class="text-dusty-500 text-[0.85rem] mb-3">{frontmatter.description}</p>
            )}
            <time class="text-dusty-600 text-[0.75rem] font-mono">{frontmatter.date}</time>
          </header>

          <!-- Post Body (rendered markdown) -->
          <article class="blog-content">
            <slot />
          </article>

        </main>
      </div>

    </div>
  </body>
</html>
